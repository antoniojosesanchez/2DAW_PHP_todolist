{% extends "template.twig" %}
{% block main %}
    <h1>Editar tarea</h1>

    <form action="{{ route("tarea.editar") }}" method="POST">

        <input type="hidden" name="id" value="{{ tarea.id }}" />

        <!-- Descripción -->
        <div class="mb-3">
            <label for="descripcion" class="form-label">Descripción</label>
            <textarea
                    class="form-control"
                    id="descripcion"
                    name="descripcion"
                    rows="3"
                    placeholder="Describe la tarea"
                    required>{{ tarea.descripcion }}</textarea>
        </div>

        <!-- Fecha -->
        <div class="mb-3">
            <label for="fecha" class="form-label">Fecha</label>
            <input
                    type="date"
                    class="form-control"
                    id="fecha"
                    name="fecha"
                    value="{{ tarea.fecha|date("Y-m-d") }}"
                    readonly>
        </div>

        <!-- Completada -->
        <div class="mb-3">
            <label class="form-label">¿Completada?</label>
            <div class="form-check">
                <input
                        class="form-check-input"
                        type="radio"
                        name="completada"
                        id="completada_si"
                        value="1"
                        {% if tarea.completada|default('0') == '1' %}checked{% endif %}
                        required>
                <label class="form-check-label" for="completada_si">
                    Sí
                </label>
            </div>
            <div class="form-check">
                <input
                        class="form-check-input"
                        type="radio"
                        name="completada"
                        id="completada_no"
                        value="0"
                        {% if tarea.completada|default('0') == '0' %}checked{% endif %}>
                <label class="form-check-label" for="completada_no">
                    No
                </label>
            </div>
        </div>

        <!-- Botón -->
        <div class="d-grid">
            <button class="btn btn-success">
                Actualizar tarea
            </button>
        </div>
    </form>
{% endblock %}