{% extends "template.twig" %}
{% block main %}
    {% set esEdicion = tarea is defined %}
    <h1>{{ esEdicion ? "Editar tarea" : "Crear nueva tarea" }}</h1>

    <form action="{{ esEdicion ? route("tarea.editar") : route("tarea.nueva") }}" method="POST">
        {% if esEdicion %}
        <input type="hidden" name="id" value="{{ tarea.id }}" />
        {% endif %}

        <!-- Descripción -->
        <div class="mb-3">
            <label for="descripcion" class="form-label">Descripción</label>
            <textarea
                    class="form-control"
                    id="descripcion"
                    name="descripcion"
                    rows="3"
                    placeholder="Describe la tarea"
                    required>{{ tarea.descripcion|default('') }}</textarea>
        </div>

        <!-- Fecha -->
        <div class="mb-3">
            <label for="fecha" class="form-label">Fecha</label>
            <input
                    type="date"
                    class="form-control"
                    id="fecha"
                    name="fecha"
                    value="{{ tarea.fecha|default('')|date('Y-m-d') }}"
                    {% if esEdicion %}readonly{% endif %}
                    required>
        </div>

        <!-- Categoría -->
        <div class="mb-3">
            <label for="categoria" class="form-label">Categoría</label>
            <select class="form-select" id="categoria" name="categoria" required>
                <option value="">Seleccione una categoría</option>
                {% for categoria in categorias %}
                <option value="{{ categoria.id }}" {{ tarea.idCategoria|default(null) == categoria.id ? 'selected' : '' }}>{{ categoria.nombre }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- Completada -->
        <div class="mb-3">
            <label class="form-label">¿Completada?</label>
            <div class="form-check">
                <input
                        class="form-check-input"
                        type="radio"
                        name="completada"
                        id="completada_si"
                        value="1"
                        {% if tarea.completada|default('0') == '1' %}checked{% endif %}
                        required>
                <label class="form-check-label" for="completada_si">
                    Sí
                </label>
            </div>
            <div class="form-check">
                <input
                        class="form-check-input"
                        type="radio"
                        name="completada"
                        id="completada_no"
                        value="0"
                        {% if tarea.completada|default('0') == '0' %}checked{% endif %}>
                <label class="form-check-label" for="completada_no">
                    No
                </label>
            </div>
        </div>

        <!-- Botones -->
        <div class="d-flex gap-2">
            <a href="{{ route("main") }}" class="btn btn-danger">Volver</a>
            <button class="btn btn-success">
                {{ esEdicion ? "Actualizar tarea" : "Guardar tarea" }}
            </button>
        </div>
    </form>
{% endblock %}
