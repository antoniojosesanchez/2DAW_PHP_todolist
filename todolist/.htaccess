RewriteEngine On

# Sintaxis: RewriteRule PATRON DESTINO [FLAGS]
# - PATRON: expresión regular sobre la URL solicitada (sin dominio ni query string).
# - DESTINO: redirección interna al script PHP con parámetros GET.
# - FLAG QSA: conserva la query original
# - FLAG L: al coincidir la regla, Apache la aplica  y ya no evalúa las siguientes

RewriteRule ^main$          index.php?modelo=tarea&metodo=list   [QSA,L]
RewriteRule ^logout$        index.php?modelo=auth&metodo=logout  [QSA,L]
RewriteRule ^tarea/nueva$   index.php?modelo=tarea&metodo=create [QSA,L]

# (?:/([1-9][0-9]*))? hace opcional el tramo "/id" al final.
RewriteRule ^tarea/editar(?:/([1-9][0-9]*))?$    index.php?modelo=tarea&metodo=editar&id=$1 [QSA,L]
RewriteRule ^tarea/borrar/([1-9][0-9]*)$    index.php?modelo=tarea&metodo=borrar&id=$1 [QSA,L]